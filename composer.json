{
    "name": "moukrea/cairn-p2p",
    "description": "cairn P2P connectivity library for PHP",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/moukrea/cairn",
    "require": {
        "php": ">=8.2",
        "ext-gmp": "*",
        "ext-openssl": "*",
        "ext-sodium": "*",
        "react/dns": "^1.12",
        "react/event-loop": "^1.4",
        "react/socket": "^1.15",
        "ramsey/uuid": "^4.7",
        "endroid/qr-code": "^5.0",
        "evenement/evenement": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9",
        "symfony/yaml": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Cairn\\": "src/"
        },
        "classmap": [
            "src/Config.php",
            "src/Channel.php",
            "src/Session.php",
            "src/Crypto/Ratchet.php",
            "src/Crypto/Noise.php",
            "src/Error/CairnException.php",
            "src/Pairing/PairingPayload.php",
            "src/Pairing/StateMachine.php",
            "src/Transport/Nat.php",
            "src/Transport/Chain.php",
            "src/Transport/Migration.php",
            "src/Transport/Heartbeat.php",
            "src/Transport/Tcp.php",
            "src/Mesh/Router.php",
            "src/Mesh/Relay.php",
            "src/Discovery/Mdns.php",
            "src/Discovery/Dht.php",
            "src/Discovery/Tracker.php",
            "src/Discovery/Rendezvous.php",
            "src/Server/Forward.php",
            "src/Server/Management.php"
        ],
        "files": [
            "src/Channel.php",
            "src/Server/Forward.php",
            "src/Discovery/Rendezvous.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Cairn\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "check": "phpstan analyse --memory-limit=512M"
    },
    "config": {
        "sort-packages": true
    }
}
